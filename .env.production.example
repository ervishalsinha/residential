APP_NAME=Residential Community Platform API
APP_VERSION=1.0.0
ENVIRONMENT=production

# Neon Postgres via SQLAlchemy. Keep sslmode=require.
# Use your own rotated credentials and host.
DATABASE_URL=postgresql+psycopg2://USER:PASSWORD@HOST/DBNAME?sslmode=require
AUTO_CREATE_TABLES=false

# Generate a long random value for production.
JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

FCM_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

WHATSAPP_ENABLED=false
WHATSAPP_META_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_PROVIDER_URL=
TENANT_APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.example.easystay
TENANT_APP_IOS_URL=https://apps.apple.com/app/example-easy-stay/id1234567890

# Add your deployed frontends here (comma-separated).
CORS_ORIGINS=https://admin.yourdomain.com,https://app.yourdomain.com
