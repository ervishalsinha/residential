APP_NAME=Residential Community Platform API
APP_VERSION=1.0.0
ENVIRONMENT=development

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/residential_platform
AUTO_CREATE_TABLES=false

JWT_SECRET_KEY=replace-with-strong-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_MINUTES=10080
OTP_EXPIRE_MINUTES=5
OTP_LENGTH=6

FCM_ENABLED=false
FIREBASE_CREDENTIALS_PATH=

WHATSAPP_ENABLED=false
WHATSAPP_META_API_VERSION=v25.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_TEMPLATE_NAME=hello_world
WHATSAPP_TEMPLATE_LANGUAGE=en_US
WHATSAPP_PROVIDER_URL=https://example-whatsapp-gateway.com/send?to={phone}&text={message}
TENANT_APP_ANDROID_URL=https://play.google.com/store/apps/details?id=com.example.easystay
TENANT_APP_IOS_URL=https://apps.apple.com/app/example-easy-stay/id1234567890

RAZORPAY_ENABLED=false
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_BASE_FOLDER=residential-os
IMAGE_UPLOAD_MAX_BYTES=5242880

CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://localhost:8081
